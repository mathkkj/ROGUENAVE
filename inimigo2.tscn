[sub_resource type="GDScript" id="GDScript_sd8qh"]
script/source = "extends Inimigos

@export var distancia_minima := 300.0
@export var distancia_maxima := 400.0

var direcao_orbita := 1.0


func _physics_process(delta: float) -> void:

	if not is_instance_valid(alvo):
		return

	mirar()

	var distancia := global_position.distance_to(alvo.global_position)

	var direcao_para_alvo := (alvo.global_position - global_position).normalized()

	var direcao_desejada := Vector2.ZERO
	
	
	match estado_atual:

		ESTADOS.NAO_CACANDO:
			velocity = velocity.move_toward(
				Vector2.ZERO,
				desaceleracao * delta
			)

			if LOS.get_collider() == alvo:
				estado_atual = ESTADOS.CACANDO


		ESTADOS.CACANDO:
			if LOS.get_collider() == alvo:
				# muito perto: foge
				if distancia < distancia_minima:
					direcao_desejada = -direcao_para_alvo

				# muito longe: aproxima
				elif distancia > distancia_maxima:
					direcao_desejada = direcao_para_alvo

				# distancia ideal -> orbita o jogador
				
				var direcao_path := escolher_dir(direcao_desejada, delta)

				var desired_velocity := (direcao_path * max_speed)

				var steering := (desired_velocity - velocity)
				steering = steering.limit_length(max_accel * delta)

				velocity += steering
		else:
			direcao_para_alvo := (alvo.global_position - global_position).normalized()
			# perdeu visao do alvo
			if LOS.get_collider() != alvo:
				estado_atual = ESTADOS.NAO_CACANDO


		ESTADOS.HIT:
			velocity = knockback_force


	move_and_slide()

func atirar():
	var projetil = projetil_instancia.instantiate()
	if not is_instance_valid(alvo):
			return
	projetil.global_position = global_position
	projetil.direcao = (alvo.global_position - projetil.global_position).normalized()
	projetil.rotation = projetil.direcao.angle()


	get_tree().current_scene.add_child(projetil)
"

